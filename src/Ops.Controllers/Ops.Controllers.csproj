      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Ocuda\MaricopaCountyAssessorHelper\MaricopaCountyAssessorHelper.csproj" />
    <ProjectReference Include="..\Ocuda\Models\Models.csproj" />
    <ProjectReference Include="..\Ops.Service\Ops.Service.csproj" />
    <ProjectReference Include="..\Ocuda\PolarisHelper\PolarisHelper.csproj" />
    <ProjectReference Include="..\Ocuda\TrestleHelper\TrestleHelper.csproj" />
